# grok-xhigh — DEPRECATED name; Grok 4.5 has no xhigh effort.
#
# Grok 4.5 supports only: high | medium | low (default high).
# This loadout is kept so old prompts `armory grok-xhigh ...` still work.
# It is identical to `grok-high` (model grok-4.5, effort high).
#
# Prefer: armory grok-high -w <name> -p "..."
#
# Intended for Fable advisor sessions only. Pure Grok sessions use native subagents.

export LLM_PRESET=grok-xhigh
export LLM_GROK=1
export GROK_MODEL=grok-4.5
export GROK_EFFORT=high

# Executor contract (persistence, one-commit-per-task, PROGRESS.md, RESULT: line).
export LLM_SYSTEM_APPEND="$(cat "$PRESETS_DIR/executor-append.txt")"
