# grok-medium — Grok 4.5 executor at effort medium.
#
# Grok 4.5 efforts: high | medium | low only (no xhigh).
# Use medium for routine, file-bounded, low-risk tasks.
# Use grok-high for ⚠ / security / billing / multi-file hard design.
#
#   armory grok-medium -w <name> -p "..."

export LLM_PRESET=grok-medium
export LLM_GROK=1
export GROK_MODEL=grok-4.5
export GROK_EFFORT=medium

export LLM_SYSTEM_APPEND="$(cat "$PRESETS_DIR/executor-append.txt")"
