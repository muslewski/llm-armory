# balanced — paid executor lane. DeepSeek V4-Pro plays the sonnet role in the
# fleet: judgment stays on native Max (opus), implementation runs here.
#
# Provider: DeepSeek direct (platform.deepseek.com), first-party Anthropic-
# compatible endpoint — NOT OpenRouter (aggregator fee + provider routing
# variance; official price is the floor anyway). Official pricing 2026-07:
#   v4-pro:   $0.435/M in (cache miss), $0.003625/M in (cache HIT), $0.87/M out
#   v4-flash: $0.14/M  in (cache miss), $0.0028/M   in (cache HIT), $0.28/M out
# Agentic sessions are cache-hit heavy — effective cost is pennies per session.
#
# Model mapping copied from the official DeepSeek Claude Code integration doc
# (api-docs.deepseek.com/quick_start/agent_integrations/claude_code):
# pro[1m] = 1M-context variant for the main tiers, flash for the haiku slot.
# If the pool ever rejects "[1m]", fall back to plain deepseek-v4-pro —
# preflight fails loud on a bad id, so a wrong pin cannot launch silently.
export LLM_PRESET=balanced
export LLM_REQUIRES_CREDENTIAL=1
[[ -f "$PRESETS_DIR/providers/deepseek.env" ]] && source "$PRESETS_DIR/providers/deepseek.env"
export ANTHROPIC_MODEL='deepseek-v4-pro[1m]'
export ANTHROPIC_DEFAULT_OPUS_MODEL='deepseek-v4-pro[1m]'
export ANTHROPIC_DEFAULT_SONNET_MODEL='deepseek-v4-pro[1m]'
export ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
export ANTHROPIC_SMALL_FAST_MODEL=deepseek-v4-flash
export CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
# Official doc recommends max effort for DeepSeek; output is cheap enough.
export CLAUDE_CODE_EFFORT_LEVEL=max
export API_TIMEOUT_MS=600000
# Fleet child contract — same as the free lane, NOT a weak-model crutch:
# the orchestrator's monitoring recipe (PROGRESS.md heartbeat, RESULT: line,
# commit-per-task) assumes every executor child follows it. The guardrail
# hooks are deterministic tripwires with 0 false positives on real repos.
# To run a vanilla capable session instead, delete the next two lines.
export LLM_EXECUTOR_HOOKS=1
export LLM_SYSTEM_APPEND="$(cat "$PRESETS_DIR/executor-append.txt")"
