# grok-xhigh — SuperGrok Heavy executor lane (headless via `grok` CLI).
#
# One of the main loadouts in the llm-armory.
#
# Intended for explicit use from Claude Code CLI / Fable advisor sessions:
#   - Fable (Claude) stays top-level advisor: judgment, planning, architecture, review.
#   - Arm yourself with this lane when you want heavy implementation executed by Grok at xhigh effort.
#   - Grok children can use their own native subagents.
#
# This lane is independent of the old free/balanced/glm cloud lanes.
# Pure Grok sessions should use native subagents instead of pulling from the armory.
#
# Launch examples (from Fable or manually):
#   armory grok-xhigh -p "Implement the plan in docs/plan.md. Work in this dir."
#   armory grok-xhigh -p "..." -w my-feature   # starts child in a fresh git worktree
#   armory grok-xhigh -p "..." --max-turns 30
#
# Flags like -w/--worktree, --no-subagents, --model, --cwd are passed through.
# The launcher forces: --always-approve + --effort xhigh + executor contract rules.

export LLM_PRESET=grok-xhigh
export LLM_GROK=1
export GROK_EFFORT=xhigh

# Executor contract (persistence, one-commit-per-task, PROGRESS.md, RESULT: line).
# Injected via `grok --rules`. The text is deliberately tool-agnostic.
export LLM_SYSTEM_APPEND="$(cat "$PRESETS_DIR/executor-append.txt")"

# No ANTHROPIC_* or REQUIRES_CREDENTIAL — grok uses its own auth (login cache or XAI_API_KEY).
# No preflight to the old pool.
