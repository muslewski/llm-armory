# freellmapi — self-hosted free-tier aggregator (Task 5).
# Copy to freellmapi.env; key comes from its Keys page after install.
# Port: host 8791 (container listens 3001 internally; PORT=8791 in src/.env maps it).
# 3000-3010 are reserved for local web-dev — do not use them here.
export ANTHROPIC_BASE_URL=http://localhost:8791
export ANTHROPIC_AUTH_TOKEN=REPLACE_ME
