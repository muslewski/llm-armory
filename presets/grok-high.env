# grok-high — primary Grok 4.5 executor lane (headless via `grok` CLI).
#
# Grok 4.5 efforts are ONLY: high | medium | low. There is no xhigh.
# This loadout pins the max supported effort: high.
#
# Fable advisor sessions:
#   - Fable stays top-level advisor (judgment / plan / review / merge).
#   - Arm this lane for implementation volume.
#   - Grok children may use their own native subagents.
#
# Launch:
#   armory grok-high -p "Implement the plan. Work in this dir."
#   armory grok-high -p "..." -w my-feature
#   armory grok-high -p "..." --max-turns 40
#
# Injects: --always-approve --model grok-4.5 --effort high --rules <contract>

export LLM_PRESET=grok-high
export LLM_GROK=1
export GROK_MODEL=grok-4.5
export GROK_EFFORT=high

# Executor contract (persistence, one-commit-per-task, PROGRESS.md, RESULT: line).
# Injected via `grok --rules`. The text is deliberately tool-agnostic.
export LLM_SYSTEM_APPEND="$(cat "$PRESETS_DIR/executor-append.txt")"

# No ANTHROPIC_* or REQUIRES_CREDENTIAL — grok uses its own auth (login cache or XAI_API_KEY).
