# free — $0 tier via self-hosted freellmapi (multi-provider pool, auto-failover).
#
# Models are PINNED, not 'auto'. Auto routes per-REQUEST by availability: the
# 2026-07-06 bake-off hour served 59 different models across 12 providers, so
# each turn of a child session got a different model — incoherent multi-step
# work (hallucinated imports, deliberation written into files). A pinned ID
# still fails over across the providers hosting that model.
# deepseek-v4-flash-free is deliberately NOT pinned: it leaks raw chain-of-
# thought into message text. Re-verify pins with: bin/llm-pool-report
export LLM_PRESET=free
export LLM_REQUIRES_CREDENTIAL=1
[[ -f "$PRESETS_DIR/providers/freellmapi.env" ]] && source "$PRESETS_DIR/providers/freellmapi.env"
export ANTHROPIC_MODEL=moonshotai/kimi-k2.6
export ANTHROPIC_DEFAULT_OPUS_MODEL=moonshotai/kimi-k2.6
export ANTHROPIC_DEFAULT_SONNET_MODEL=moonshotai/kimi-k2.6
export ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.7
export ANTHROPIC_SMALL_FAST_MODEL=glm-4.7
export CLAUDE_CODE_SUBAGENT_MODEL=moonshotai/kimi-k2.6
export API_TIMEOUT_MS=600000
# Inject executor guardrail hooks (post-edit TS check + stop gate) via
# --settings hooks/executor-settings.json. See bin/llm launch case.
export LLM_EXECUTOR_HOOKS=1
# Free-pool models end their turn after each step; force plan-scale persistence
# plus the execution discipline distilled from the 2026-07-06 bake-off postmortem.
# Shared across executor presets — edit presets/executor-append.txt, not here.
export LLM_SYSTEM_APPEND="$(cat "$PRESETS_DIR/executor-append.txt")"
