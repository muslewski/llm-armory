#!/usr/bin/env bash
# armory — llm-armory executor launcher
# Lanes / loadouts: $LLM_ARMORY_HOME/presets/*.env  (default: ~/Repositories/llm-armory)
# This is the implementation of llm-armory — choose the right executor for the job.
#
# THE ONE ABSOLUTE CONSTRAINT: `armory <loadout> -p <prompt>` is production
# infrastructure. Exec of the child CLI, exit-code propagation, prompt passing,
# and no-TTY operation MUST stay byte-compatible. All chrome → stderr and
# silences when stderr is not a TTY (kit law).
set -euo pipefail

# Support both new name and legacy LLM_LAB_HOME for transition
ARMORY_HOME="${LLM_ARMORY_HOME:-${LLM_LAB_HOME:-$HOME/Repositories/llm-armory}}"
PRESETS_DIR="$ARMORY_HOME/presets"
export ARMORY_HOME
export LLM_ARMORY_HOME="$ARMORY_HOME"  # for future
export LLM_LAB_HOME="$ARMORY_HOME"     # compat for old hooks
export PRESETS_DIR   # preset files use it to source providers/*.env

# GREEN-UI-KIT (or plain fallbacks). Path override: GREEN_UI=/path/to/green-ui.sh
_ARMORY_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
# shellcheck source=lib/ui.sh
source "$_ARMORY_ROOT/lib/ui.sh"

# Primary loadout for ★ marking (statusline / list).
ARMORY_PRIMARY_LOADOUT="${ARMORY_PRIMARY_LOADOUT:-grok-high}"

usage() {
  local cmd="${0##*/}"
  if [[ "$cmd" == "llm" ]]; then
    cmd="armory"
  fi

  cat >&2 <<EOF
$cmd — llm-armory (choose the right executor for the job)

Usage:
  $cmd --list                  arsenal rack (loadouts + READY/SKIP/DEAD)
  $cmd --dry-run <loadout>     mission card: preview what will be launched
  $cmd pick                    fzf/numbered pick then launch
  $cmd doctor                  whole-armory health checklist
  $cmd <loadout> [args...]     arm and launch an executor loadout
                               (quality = native Fable advisor)
                               (grok-high = Grok 4.5 @ effort high)

Loadouts live in \$ARMORY_HOME/presets (default ~/Repositories/llm-armory/presets).

Primary use (from Fable advisor sessions):
  $cmd quality                 pure Fable/Max advisor session
  $cmd grok-high -p "..." -w my-worktree
                               arm with Grok 4.5 (effort high)
                               Headless grok with model pin + contract.
                               -w: armory materializes <repo>/.claude/worktrees/<name>
                               (branch <name>) and launches the child there via --cwd
                               (grok's own -w is a silent no-op in headless mode).

Note: Grok 4.5 efforts are high|medium|low only — there is no xhigh.
      Loadout name grok-xhigh is a deprecated alias of grok-high.
      This armory is for Claude CLI (Fable) sessions; pure Grok uses native subagents.
      (You can still invoke this binary as \`llm\` during transition.)
EOF
}

resolve() {
  local preset=$1
  local file="$PRESETS_DIR/$preset.env"
  if [[ ! -f "$file" ]]; then
    echo "armory: unknown loadout '$preset' (looked in $PRESETS_DIR)" >&2
    echo -n "armory: available:" >&2
    for f in "$PRESETS_DIR"/*.env; do [[ -e "$f" ]] && echo -n " $(basename "$f" .env)" >&2; done
    echo >&2
    exit 1
  fi
  sanitize_parent_loadout
  set -a
  # shellcheck disable=SC1090
  source "$file"
  set +a
}

# sanitize_parent_loadout clears any control variables that may have been
# exported by a parent armory loadout (e.g. running inside a grok-high child
# and then invoking `armory quality` or `armory --list`). Without this, parent
# state pollutes classification (grok path taken for non-grok presets) and
# resolved config for other loadouts.
sanitize_parent_loadout() {
  # Clear only vars that a preset .env file is expected to (re)define for its
  # own identity. Leave caller overrides like LLM_SKIP_PREFLIGHT alone.
  unset LLM_GROK GROK_EFFORT GROK_MODEL LLM_PRESET LLM_REQUIRES_CREDENTIAL \
        ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ANTHROPIC_API_KEY ANTHROPIC_MODEL \
        ANTHROPIC_DEFAULT_OPUS_MODEL ANTHROPIC_DEFAULT_SONNET_MODEL ANTHROPIC_DEFAULT_HAIKU_MODEL \
        ANTHROPIC_SMALL_FAST_MODEL CLAUDE_CODE_SUBAGENT_MODEL CLAUDE_CODE_EFFORT_LEVEL \
        API_TIMEOUT_MS LLM_SYSTEM_APPEND LLM_EXECUTOR_HOOKS
}

is_grok_loadout() {
  [[ "${LLM_GROK:-0}" == "1" || "${1:-${LLM_PRESET:-}}" == grok* ]]
}

check_auth() {
  # Grok presets use separate auth (grok login / XAI_API_KEY). Skip Anthropic checks.
  if is_grok_loadout; then
    return 0
  fi

  # A preset that requires provider credentials (LLM_REQUIRES_CREDENTIAL) must
  # have resolved either a remote endpoint or an API key. If its provider file
  # was missing, nothing resolved — refuse, rather than silently falling back
  # to the native Max endpoint with a bogus model.
  if [[ -n "${LLM_REQUIRES_CREDENTIAL:-}" && -z "${ANTHROPIC_BASE_URL:-}" && -z "${ANTHROPIC_API_KEY:-}" ]]; then
    echo "armory: loadout '${LLM_PRESET:-?}' needs provider credentials but none are configured." >&2
    echo "armory: copy presets/providers/<provider>.env.example to <provider>.env and add your key." >&2
    exit 1
  fi
  if [[ -n "${ANTHROPIC_BASE_URL:-}" && -z "${ANTHROPIC_AUTH_TOKEN:-}${ANTHROPIC_API_KEY:-}" ]]; then
    echo "armory: loadout '${LLM_PRESET:-?}' sets ANTHROPIC_BASE_URL but no ANTHROPIC_AUTH_TOKEN/ANTHROPIC_API_KEY." >&2
    echo "armory: copy presets/providers/<provider>.env.example to <provider>.env and add your key." >&2
    exit 1
  fi
}

# Auth probe for doctor/list badges (never exits).
auth_ok_quiet() {
  if is_grok_loadout; then
    # Grok: binary presence is the hard check; login cache optional.
    return 0
  fi
  if [[ -n "${LLM_REQUIRES_CREDENTIAL:-}" && -z "${ANTHROPIC_BASE_URL:-}" && -z "${ANTHROPIC_API_KEY:-}" ]]; then
    return 1
  fi
  if [[ -n "${ANTHROPIC_BASE_URL:-}" && -z "${ANTHROPIC_AUTH_TOKEN:-}${ANTHROPIC_API_KEY:-}" ]]; then
    return 1
  fi
  return 0
}

# READY | SKIP | DEAD — binary present? key present?
loadout_badge() {
  local name=$1
  if is_grok_loadout "$name"; then
    if command -v grok >/dev/null 2>&1; then
      printf 'READY'
    else
      printf 'DEAD'
    fi
    return 0
  fi
  if ! command -v claude >/dev/null 2>&1; then
    printf 'DEAD'
    return 0
  fi
  if ! auth_ok_quiet; then
    printf 'SKIP'
    return 0
  fi
  printf 'READY'
}

preflight() {
  # Grok lane has its own preflight (binary presence + version).
  if is_grok_loadout; then
    return 0
  fi

  # Probe the pool before launching a child. A dead/exhausted pool used to
  # produce zero-work children that exited 0 (2026-07-06 bake-off: 2 of 6
  # launches were dead on arrival). Fail loud and nonzero instead.
  # Skip: native Max (no BASE_URL) or LLM_SKIP_PREFLIGHT=1.
  [[ -z "${ANTHROPIC_BASE_URL:-}" || -n "${LLM_SKIP_PREFLIGHT:-}" ]] && return 0
  local model="${ANTHROPIC_MODEL:-auto}" out http
  out=$(curl -s -m 45 -w $'\n%{http_code}' "$ANTHROPIC_BASE_URL/v1/messages" \
    -H "x-api-key: ${ANTHROPIC_AUTH_TOKEN:-${ANTHROPIC_API_KEY:-}}" \
    -H "anthropic-version: 2023-06-01" -H "content-type: application/json" \
    -d "{\"model\":\"$model\",\"max_tokens\":1,\"messages\":[{\"role\":\"user\",\"content\":\"ping\"}]}" 2>&1) || {
    echo "armory: preflight FAILED — cannot reach $ANTHROPIC_BASE_URL ($out)" >&2
    echo "armory: set LLM_SKIP_PREFLIGHT=1 to launch anyway." >&2
    exit 1
  }
  http="${out##*$'\n'}"
  if [[ "$http" != 2* ]]; then
    echo "armory: preflight FAILED — HTTP $http from pool for model '$model' (dead or exhausted):" >&2
    printf '%s' "${out%$'\n'*}" | head -c 300 >&2; echo >&2
    echo "armory: set LLM_SKIP_PREFLIGHT=1 to launch anyway." >&2
    exit 1
  fi
  echo "✓ preflight: '$model' responding at $ANTHROPIC_BASE_URL" >&2
}

# Classic monoline executor identity — always on stderr (launch-path contract).
# Kept for non-TTY / nohup logs and existing golden greps.
emit_executor_line() {
  if is_grok_loadout; then
    local effort="${GROK_EFFORT:-high}"
    local model="${GROK_MODEL:-grok-4.5}"
    echo "▶ executor: ${model} (effort=${effort}) @ SuperGrok Heavy (loadout: ${LLM_PRESET:-?})" >&2
  else
    local model="${ANTHROPIC_MODEL:-claude (native)}" host
    if [[ -n "${ANTHROPIC_BASE_URL:-}" ]]; then
      host="$ANTHROPIC_BASE_URL"
    elif [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
      host="api.anthropic.com (API-billed)"
    else
      host="api.anthropic.com (Max subscription)"
    fi
    echo "▶ executor: ${model} @ ${host} (loadout: ${LLM_PRESET:-?})" >&2
  fi
}

# Compat aliases used historically / by dry-run paths that called banner.
banner() { emit_executor_line; }
grok_banner() { emit_executor_line; }

# Compact arm checklist + mission banner on TTY only (kit law).
# Non-TTY: silent — only emit_executor_line remains for logs.
arm_sequence() {
  local phase=${1:-launch}  # launch | dry-run (dry-run skips armed banner)
  if ! ui_tty; then
    return 0
  fi

  local sf bin_state auth_state
  sf=$(mktemp 2>/dev/null) || sf="${TMPDIR:-/tmp}/armory-arm.$$.$RANDOM"
  : >"$sf"

  check_set "$sf" resolve done

  if is_grok_loadout; then
    if command -v grok >/dev/null 2>&1; then bin_state=done; else bin_state=failed; fi
  else
    if command -v claude >/dev/null 2>&1; then bin_state=done; else bin_state=failed; fi
  fi
  check_set "$sf" binary "$bin_state"

  if auth_ok_quiet; then auth_state=done; else auth_state=failed; fi
  check_set "$sf" auth "$auth_state"
  check_set "$sf" arm done

  checklist "$sf" \
    "resolve:resolve loadout" \
    "binary:check binary" \
    "auth:check auth/key" \
    "arm:arm"
  rm -f "$sf" 2>/dev/null || true

  if [[ $phase == launch ]]; then
    local model effort host sub
    if is_grok_loadout; then
      model="${GROK_MODEL:-grok-4.5}"
      effort="${GROK_EFFORT:-high}"
      sub="${model} @ ${effort} · ${LLM_PRESET:-?}"
    else
      model="${ANTHROPIC_MODEL:-claude (native)}"
      sub="${model} · ${LLM_PRESET:-?}"
    fi
    # kit banner (chrome) — only when TTY
    # Note: our emit_executor_line overrides name "banner" above; call via
    # progress-free plain box if kit banner was shadowed. Reconstruct lightly:
    printf '%s\n' "⚔ ARMED · ${sub}" >&2
  fi
}

# Grok preflight: just ensure the binary is available and looks runnable.
# (Grok auth is handled by its own login cache / XAI_API_KEY; no pool probe.)
grok_preflight() {
  if ! command -v grok >/dev/null 2>&1; then
    echo "armory: 'grok' command not found in PATH. Is ~/.grok/bin on PATH or is grok installed?" >&2
    exit 1
  fi
  # Quick sanity (non-interactive). If this fails the user will see grok's error.
  if ! grok --version >/dev/null 2>&1; then
    echo "armory: 'grok --version' failed; check grok installation and auth (try 'grok login')." >&2
    exit 1
  fi
}

# --- Agent Status Provider helpers (schema 1) ---
# Soft-fail law: record writing must NEVER break or delay a launch.
# Every call site is guarded (`|| true`); helpers return 0 on any failure.
# Convention: readers pid-check written_by=llm-armory records (long TTL + pid).

# 1. $AGENT_STATUS_DIR  2. $XDG_RUNTIME_DIR/agent-status  3. ~/.local/state/agent-status
agent_status_dir() {
  if [[ -n "${AGENT_STATUS_DIR:-}" ]]; then
    printf '%s' "$AGENT_STATUS_DIR"
  elif [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
    printf '%s/agent-status' "$XDG_RUNTIME_DIR"
  else
    printf '%s/.local/state/agent-status' "${HOME:-/tmp}"
  fi
}

# minimal JSON string escaping: backslash, double-quote, newline/tab → \\ \" \n \t
json_escape() {
  local s=${1-}
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  s=${s//$'\n'/\\n}
  s=${s//$'\r'/\\r}
  s=${s//$'\t'/\\t}
  printf '%s' "$s"
}

# Atomic write: mktemp in destination dir + mv -f (same-filesystem rename).
# Always returns 0 (soft-fail).
_agent_status_atomic_write() {
  local dest=$1
  local content=$2
  local dir tmp
  dir=$(dirname -- "$dest") || return 0
  mkdir -p "$dir" 2>/dev/null || return 0
  tmp=$(mktemp --tmpdir="$dir" .tmp.XXXXXX 2>/dev/null) \
    || tmp=$(mktemp "$dir/.tmp.XXXXXX" 2>/dev/null) \
    || return 0
  if ! printf '%s' "$content" >"$tmp" 2>/dev/null; then
    rm -f "$tmp" 2>/dev/null || true
    return 0
  fi
  if ! mv -f "$tmp" "$dest" 2>/dev/null; then
    rm -f "$tmp" 2>/dev/null || true
    return 0
  fi
  return 0
}

# Write session record + provider heartbeat. Always returns 0 (soft-fail law).
# Usage: write_agent_status_record <child_cli> [user_args...]
# child_cli: "grok" | "claude"
# Record path: <dir>/sessions/<child_cli>-pid$$.json (pid-key fallback; no session id pre-exec).
# Because exec replaces this process, $$ is the child pid after launch.
write_agent_status_record() {
  local child_cli=${1:-}
  shift || true
  [[ -n "$child_cli" ]] || return 0

  local base worktree="" model="" effort="" preset parent cwd ts key
  local arg prev="" json hb_json

  # Parse -w / --worktree from remaining user args (omit field when absent).
  for arg in "$@"; do
    if [[ "$prev" == "-w" || "$prev" == "--worktree" ]]; then
      worktree=$arg
      break
    fi
    # support --worktree=value form
    if [[ "$arg" == --worktree=* ]]; then
      worktree=${arg#--worktree=}
      break
    fi
    prev=$arg
  done

  base=$(agent_status_dir 2>/dev/null) || return 0
  [[ -n "$base" ]] || return 0

  mkdir -p "$base/sessions" "$base/providers" 2>/dev/null || return 0

  ts=$(date +%s%3N 2>/dev/null) || ts=""
  if [[ -z "$ts" || "$ts" == *%* ]]; then
    ts=$(date +%s 2>/dev/null) || return 0
    ts="${ts}000"
  fi

  preset=${LLM_PRESET:-}
  parent=${SAGE_PARENT:-}
  cwd=$(pwd -P 2>/dev/null || pwd 2>/dev/null || printf '')

  if [[ "$child_cli" == "grok" ]]; then
    model=${GROK_MODEL:-}
    effort=${GROK_EFFORT:-}
  else
    model=${ANTHROPIC_MODEL:-}
    effort=${CLAUDE_CODE_EFFORT_LEVEL:-}
  fi

  key="${child_cli}-pid$$"

  # Build session JSON (pretty enough for greppable "key": "value" form);
  # omit empty optional keys (no nulls).
  json=$'{\n'
  json+=$'  "schema": 1,\n'
  json+="  \"source_cli\": \"$(json_escape "$child_cli")\","$'\n'
  json+="  \"pid\": $$,"$'\n'
  json+="  \"cwd\": \"$(json_escape "$cwd")\","$'\n'
  if [[ -n "$model" ]]; then
    json+="  \"model\": \"$(json_escape "$model")\","$'\n'
  fi
  if [[ -n "$effort" ]]; then
    json+="  \"effort\": \"$(json_escape "$effort")\","$'\n'
  fi
  if [[ -n "$preset" ]]; then
    json+="  \"preset\": \"$(json_escape "$preset")\","$'\n'
  fi
  if [[ -n "$worktree" ]]; then
    json+="  \"worktree\": \"$(json_escape "$worktree")\","$'\n'
  fi
  if [[ -n "$parent" ]]; then
    json+="  \"parent_session\": \"$(json_escape "$parent")\","$'\n'
  fi
  json+=$'  "written_by": "llm-armory",\n'
  json+="  \"started_at\": ${ts},"$'\n'
  json+="  \"updated_at\": ${ts},"$'\n'
  json+=$'  "ttl_ms": 43200000\n'
  json+='}'

  _agent_status_atomic_write "$base/sessions/${key}.json" "$json" || true

  hb_json=$'{\n'
  hb_json+=$'  "schema": 1,\n'
  hb_json+=$'  "tool": "llm-armory",\n'
  hb_json+="  \"pid\": $$,"$'\n'
  hb_json+="  \"ts\": ${ts},"$'\n'
  hb_json+=$'  "ttl_ms": 43200000,\n'
  hb_json+=$'  "capabilities": ["launch"]\n'
  hb_json+='}'
  _agent_status_atomic_write "$base/providers/llm-armory.json" "$hb_json" || true

  return 0
}

# Armory-owned worktree materialization for grok children.
# The grok CLI silently ignores -w/--worktree in headless -p mode (verified
# 2026-07-16, grok 0.2.101), and grok-created worktrees live under
# ~/.grok/worktrees anyway — not the repo-local .claude/worktrees/ convention.
# So the armory creates <repo>/.claude/worktrees/<name> itself, strips the
# worktree flags, and points the child at it via --cwd. Failures are LOUD:
# a silent fallback to the main checkout is exactly the bug this prevents
# (2026-07-16 fleet: 75 children all landed on their repos' main checkouts).
# Mutates the caller's args array via nameref.
prepare_grok_worktree() {
  local -n _args=$1
  local name="" ref="" cwd_base="" arg prev=""

  for arg in "${_args[@]}"; do
    case "$prev" in
      -w|--worktree) name=$arg ;;
      --worktree-ref) ref=$arg ;;
      --cwd) cwd_base=$arg ;;
    esac
    case "$arg" in
      -w=*) name=${arg#-w=} ;;
      --worktree=*) name=${arg#--worktree=} ;;
      --worktree-ref=*) ref=${arg#--worktree-ref=} ;;
      --cwd=*) cwd_base=${arg#--cwd=} ;;
    esac
    prev=$arg
  done

  # Trailing value-less flags would otherwise slip through as "no worktree".
  if (( ${#_args[@]} > 0 )); then
    case "${_args[-1]}" in
      -w|--worktree|--worktree-ref)
        echo "armory: ${_args[-1]} requires a value" >&2; exit 1 ;;
    esac
  fi

  if [[ -z "$name" && -n "$ref" ]]; then
    echo "armory: --worktree-ref requires -w/--worktree <name>" >&2; exit 1
  fi
  [[ -n "$name" ]] || return 0

  if [[ ! "$name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
    echo "armory: -w/--worktree requires a safe name (got '$name'; allowed: alnum . _ -)" >&2
    exit 1
  fi

  local toplevel
  if ! toplevel=$(git -C "${cwd_base:-$PWD}" rev-parse --show-toplevel 2>/dev/null); then
    echo "armory: -w $name: '${cwd_base:-$PWD}' is not a git repo (worktrees need one)" >&2
    exit 1
  fi

  local wt_path="$toplevel/.claude/worktrees/$name"
  mkdir -p "$toplevel/.claude/worktrees"
  if ! git -C "$toplevel" check-ignore -q .claude/worktrees 2>/dev/null; then
    echo "armory: warning: .claude/worktrees is not gitignored in $toplevel (add it — see WORKTREES.md)" >&2
  fi

  # Concurrency-safe creation: parallel fleet launches race on git's
  # index/worktree locks; retry with jitter, and treat an existing valid
  # worktree as success (idempotent relaunch).
  local attempt max_attempts=6 add_err=""
  for ((attempt = 1; attempt <= max_attempts; attempt++)); do
    if [[ -f "$wt_path/.git" ]] && git -C "$wt_path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      echo "▶ worktree: $wt_path (reusing existing)" >&2
      break
    fi
    if git -C "$toplevel" show-ref --verify --quiet "refs/heads/$name"; then
      if add_err=$(git -C "$toplevel" worktree add "$wt_path" "$name" 2>&1); then
        echo "▶ worktree: $wt_path (existing branch $name)" >&2
        break
      fi
    else
      if add_err=$(git -C "$toplevel" worktree add -b "$name" "$wt_path" ${ref:+"$ref"} 2>&1); then
        echo "▶ worktree: $wt_path (new branch $name${ref:+ from $ref})" >&2
        break
      fi
    fi
    if (( attempt == max_attempts )); then
      echo "armory: failed to create worktree $wt_path after $max_attempts attempts:" >&2
      echo "$add_err" >&2
      exit 1
    fi
    sleep "0.$(( (RANDOM % 5) + 2 ))"
  done

  # Rebuild args: drop worktree flags and any caller --cwd, then point the
  # child at the worktree.
  local rebuilt=() skip=0
  for arg in "${_args[@]}"; do
    if (( skip )); then skip=0; continue; fi
    case "$arg" in
      -w|--worktree|--worktree-ref|--cwd) skip=1 ;;
      -w=*|--worktree=*|--worktree-ref=*|--cwd=*) ;;
      *) rebuilt+=("$arg") ;;
    esac
  done
  rebuilt+=(--cwd "$wt_path")
  _args=("${rebuilt[@]}")
}

# Effort as a small text gauge (high=full, medium=mid, low=low).
effort_gauge() {
  local e=${1:-high}
  case "$e" in
    high)   printf '████ high' ;;
    medium) printf '██░░ medium' ;;
    low)    printf '█░░░ low' ;;
    *)      printf '%s' "$e" ;;
  esac
}

# stdout data lines only (no empty KEY=). Chrome via panel when TTY.
dry_run_report() {
  local name=$1
  shift || true
  local -a user_args=("$@")
  local body="" rules_len=0 rules_note="(none)"
  local model effort host would warnings=""

  if [[ -n "${LLM_SYSTEM_APPEND:-}${GROK_RULES:-}" ]]; then
    local rules="${GROK_RULES:-${LLM_SYSTEM_APPEND:-}}"
    rules_len=${#rules}
    rules_note="(set, ${rules_len} chars)"
  fi

  if is_grok_loadout "$name"; then
    model="${GROK_MODEL:-grok-4.5}"
    effort="${GROK_EFFORT:-high}"
    host="SuperGrok Heavy"
    would="grok --always-approve"
    [[ -n "${GROK_MODEL:-}" ]] && would+=" --model ${GROK_MODEL}"
    would+=" --effort ${effort}"
    [[ $rules_len -gt 0 ]] && would+=" --rules '...'"
    if (( ${#user_args[@]} > 0 )); then
      would+=" ${user_args[*]}"
    else
      would+=" [your args: -p, -w, ...]"
    fi

    # Data on stdout (existing tests + a1). Identity line keeps
    # "model (effort=…)" shape for harness greps.
    printf 'executor: %s (effort=%s) @ SuperGrok Heavy (loadout: %s)\n' \
      "$model" "$effort" "${LLM_PRESET:-$name}"
    printf 'LLM_PRESET=%s\n' "${LLM_PRESET:-}"
    printf 'GROK_MODEL=%s\n' "${GROK_MODEL:-}"
    printf 'GROK_EFFORT=%s\n' "${effort}"
    printf 'GROK_RULES (or LLM_SYSTEM_APPEND)=%s\n' "$rules_note"
    printf 'Would exec: %s\n' "$would"
    printf '(Grok auth is separate; no ANTHROPIC vars used.)\n'
    if [[ "${LLM_PRESET:-}" == "grok-xhigh" ]]; then
      warnings="loadout name grok-xhigh is deprecated; Grok 4.5 has no xhigh effort — this lane uses effort=high (same as grok-high)."
      printf 'note: %s\n' "$warnings"
    fi

    body=$(printf 'loadout %s\nmodel %s  effort %s\nrules %s\nwould: %s' \
      "${LLM_PRESET:-$name}" "$model" "$(effort_gauge "$effort")" "$rules_note" "$would")
    [[ -n $warnings ]] && body+=$(printf '\nwarn: %s' "$warnings")
  else
    model="${ANTHROPIC_MODEL:-claude (native)}"
    if [[ -n "${ANTHROPIC_BASE_URL:-}" ]]; then
      host="$ANTHROPIC_BASE_URL"
    elif [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
      host="api.anthropic.com (API-billed)"
    else
      host="api.anthropic.com (Max subscription)"
    fi
    would="claude"
    if [[ -n "${LLM_SYSTEM_APPEND:-}" ]]; then
      would+=" --append-system-prompt '...'"
    fi
    if [[ -n "${LLM_EXECUTOR_HOOKS:-}" && -f "$ARMORY_HOME/hooks/executor-settings.json" ]]; then
      would+=" --settings hooks/executor-settings.json"
    fi
    if (( ${#user_args[@]} > 0 )); then
      would+=" ${user_args[*]}"
    else
      would+=" [your args]"
    fi

    local tok="${ANTHROPIC_AUTH_TOKEN:-${ANTHROPIC_API_KEY:-}}"
    # Only non-empty KEY= lines (no empty dump)
    printf 'LLM_PRESET=%s\n' "${LLM_PRESET:-}"
    [[ -n "${ANTHROPIC_BASE_URL:-}" ]] && printf 'ANTHROPIC_BASE_URL=%s\n' "$ANTHROPIC_BASE_URL"
    [[ -n $tok ]] && printf 'ANTHROPIC_AUTH_TOKEN=%s…(masked)\n' "${tok:0:6}"
    [[ -n "${ANTHROPIC_MODEL:-}" ]] && printf 'ANTHROPIC_MODEL=%s\n' "$ANTHROPIC_MODEL"
    [[ -n "${ANTHROPIC_DEFAULT_OPUS_MODEL:-}" ]] && printf 'ANTHROPIC_DEFAULT_OPUS_MODEL=%s\n' "$ANTHROPIC_DEFAULT_OPUS_MODEL"
    [[ -n "${ANTHROPIC_DEFAULT_SONNET_MODEL:-}" ]] && printf 'ANTHROPIC_DEFAULT_SONNET_MODEL=%s\n' "$ANTHROPIC_DEFAULT_SONNET_MODEL"
    [[ -n "${ANTHROPIC_DEFAULT_HAIKU_MODEL:-}" ]] && printf 'ANTHROPIC_DEFAULT_HAIKU_MODEL=%s\n' "$ANTHROPIC_DEFAULT_HAIKU_MODEL"
    [[ -n "${CLAUDE_CODE_SUBAGENT_MODEL:-}" ]] && printf 'CLAUDE_CODE_SUBAGENT_MODEL=%s\n' "$CLAUDE_CODE_SUBAGENT_MODEL"
    [[ -n "${API_TIMEOUT_MS:-}" ]] && printf 'API_TIMEOUT_MS=%s\n' "$API_TIMEOUT_MS"
    [[ -n "${LLM_SYSTEM_APPEND:-}" ]] && printf 'LLM_SYSTEM_APPEND=%s\n' "$rules_note"
    [[ -n "${LLM_EXECUTOR_HOOKS:-}" ]] && printf 'LLM_EXECUTOR_HOOKS=%s\n' "$LLM_EXECUTOR_HOOKS"
    printf 'Would exec: %s\n' "$would"

    body=$(printf 'loadout %s\nmodel %s @ %s\nrules %s\nwould: %s' \
      "${LLM_PRESET:-$name}" "$model" "$host" "$rules_note" "$would")
  fi

  # Chrome → stderr when TTY (kit panel); silent when non-TTY.
  if ui_tty; then
    printf '%s\n' "$body" | panel "dry-run · ${LLM_PRESET:-$name}"
  fi
}

# Arsenal rack: fixed columns + badge. Data → stdout.
# Column 1 is always the loadout name (existing greps: ^name). Primary gets ★ in STATUS.
list_loadouts() {
  local found=0 name model_disp host_disp badge status
  # header (chrome-ish but still data/table on stdout)
  printf '%-12s %-32s %-28s %s\n' "LOADOUT" "MODEL" "HOST" "STATUS"
  for f in "$PRESETS_DIR"/*.env; do
    [[ -e "$f" ]] || continue
    found=1
    name=$(basename "$f" .env)
    (
      sanitize_parent_loadout
      set +e; set -a
      # shellcheck disable=SC1090
      source "$f" >/dev/null 2>&1
      set +a
      if is_grok_loadout "$name"; then
        model_disp="${GROK_MODEL:-grok-4.5}${GROK_EFFORT:+ (effort=$GROK_EFFORT)}"
        host_disp="SuperGrok Heavy (via grok CLI)"
      else
        model_disp="${ANTHROPIC_MODEL:-native}"
        host_disp="${ANTHROPIC_BASE_URL:-api.anthropic.com (Max)}"
      fi
      badge=$(loadout_badge "$name")
      status="$badge"
      [[ "$name" == "$ARMORY_PRIMARY_LOADOUT" ]] && status="${badge} ★"
      # single width for model col (fixes historical 24-vs-32 host misalignment)
      printf '%-12s %-32s %-28s %s\n' "$name" "$model_disp" "$host_disp" "$status"
    )
  done
  [[ $found -eq 1 ]] || { echo "armory: no loadouts in $PRESETS_DIR" >&2; exit 1; }
}

# Interactive pick: fzf + green_fzf_opts when available; else numbered menu.
# Prints selected loadout name on stdout, then caller launches.
pick_loadout() {
  local -a names=()
  local f name sel fopts preview_cmd
  for f in "$PRESETS_DIR"/*.env; do
    [[ -e "$f" ]] || continue
    names+=("$(basename "$f" .env)")
  done
  if (( ${#names[@]} == 0 )); then
    echo "armory: no loadouts in $PRESETS_DIR" >&2
    exit 1
  fi

  if ui_tty && command -v fzf >/dev/null 2>&1; then
    fopts=$(green_fzf_opts)
    preview_cmd="cat ${PRESETS_DIR}/{}.env 2>/dev/null | head -80"
    # shellcheck disable=SC2086
    sel=$(printf '%s\n' "${names[@]}" | fzf \
      --prompt='armory pick> ' \
      --height=60% --reverse \
      --preview "$preview_cmd" \
      --preview-window=right,50%,border-rounded \
      $fopts) || exit 130
    printf '%s\n' "$sel"
    return 0
  fi

  # Numbered fallback (kit choose or plain)
  if declare -f choose >/dev/null 2>&1; then
    choose "pick loadout" "${names[@]}"
  else
    local i n
    printf '› pick loadout\n' >&2
    for i in "${!names[@]}"; do
      printf '  %d) %s\n' "$((i + 1))" "${names[i]}" >&2
    done
    printf 'Choice [1]: ' >&2
    read -r n </dev/tty || exit 130
    [[ -z ${n-} ]] && n=1
    printf '%s\n' "${names[n - 1]}"
  fi
}

# Whole-armory health. Exit 0 healthy / 1 problems. Kit checklist on stderr.
cmd_doctor() {
  local f name problems=0 sf state
  local -a items=()
  sf=$(mktemp 2>/dev/null) || sf="${TMPDIR:-/tmp}/armory-doctor.$$.$RANDOM"
  : >"$sf"

  printf '%s\n' "doctor · armory health" >&2

  for f in "$PRESETS_DIR"/*.env; do
    [[ -e "$f" ]] || continue
    name=$(basename "$f" .env)
    items+=("${name}:${name}")
    state=done

    # Isolate preset env in a subshell; never let set -e abort the doctor loop.
    state=$(
      sanitize_parent_loadout
      set +e
      set -a
      # shellcheck disable=SC1090
      source "$f" >/dev/null 2>&1
      set +a

      if is_grok_loadout "$name"; then
        command -v grok >/dev/null 2>&1 || { printf 'failed\n'; exit 0; }
      else
        command -v claude >/dev/null 2>&1 || { printf 'failed\n'; exit 0; }
      fi
      if ! auth_ok_quiet; then
        printf 'failed\n'
        exit 0
      fi
      if [[ -f "$PRESETS_DIR/executor-append.txt" && ! -r "$PRESETS_DIR/executor-append.txt" ]]; then
        printf 'failed\n'
        exit 0
      fi
      printf 'done\n'
    ) || state=failed

    [[ -z $state ]] && state=failed
    check_set "$sf" "$name" "$state"
    if [[ $state != done ]]; then
      problems=1
    fi
  done

  if (( ${#items[@]} == 0 )); then
    echo "armory: no loadouts in $PRESETS_DIR" >&2
    rm -f "$sf"
    exit 1
  fi

  checklist "$sf" "${items[@]}"
  rm -f "$sf"

  if (( problems )); then
    echo "armory: doctor found problems (missing binary or credentials)" >&2
    exit 1
  fi
  echo "armory: doctor ok — all loadouts healthy" >&2
  exit 0
}

launch_grok() {
  local user_args=("$@")
  local orig_args=("$@")   # status record keeps the caller's -w for the worktree field
  grok_preflight
  arm_sequence launch
  emit_executor_line
  prepare_grok_worktree user_args

  local grok_cmd=(grok)
  grok_cmd+=(--always-approve)

  # Optional explicit model pin (e.g. GROK_MODEL=grok-4.5). Without this the CLI
  # default applies — which is currently grok-4.5, but pin for determinism.
  if [[ -n "${GROK_MODEL:-}" ]]; then
    grok_cmd+=(--model "${GROK_MODEL}")
  fi

  if [[ -n "${GROK_EFFORT:-}" ]]; then
    grok_cmd+=(--effort "${GROK_EFFORT}")
  fi

  # Inject executor discipline (persistence, commits, PROGRESS.md, RESULT line) via --rules.
  # Prefer explicit GROK_RULES, fall back to the shared LLM_SYSTEM_APPEND (from executor-append.txt).
  local rules="${GROK_RULES:-${LLM_SYSTEM_APPEND:-}}"
  if [[ -n "$rules" ]]; then
    grok_cmd+=(--rules "$rules")
  fi

  # Pass through everything the caller supplied (typically -p "prompt", -w/--worktree, --cwd, --max-turns, etc.).
  # User flags appearing after our controls can override (e.g. a different --effort).
  grok_cmd+=("${user_args[@]}")

  write_agent_status_record "grok" "${orig_args[@]}" || true
  exec "${grok_cmd[@]}"
}

launch_claude() {
  arm_sequence launch
  emit_executor_line
  local extra_args=()
  # Weak executor models tend to end their turn after each step; presets
  # can set LLM_SYSTEM_APPEND to inject a persistence instruction.
  if [[ -n "${LLM_SYSTEM_APPEND:-}" ]]; then
    extra_args+=(--append-system-prompt "$LLM_SYSTEM_APPEND")
  fi
  # Executor guardrails: post-edit TS/import check + uncommitted-work stop
  # gate. Opt-in per preset via LLM_EXECUTOR_HOOKS=1.
  if [[ -n "${LLM_EXECUTOR_HOOKS:-}" && -f "$ARMORY_HOME/hooks/executor-settings.json" ]]; then
    extra_args+=(--settings "$ARMORY_HOME/hooks/executor-settings.json")
  fi
  write_agent_status_record "claude" "$@" || true
  exec claude "${extra_args[@]}" "$@"
}

case "${1:-}" in
  ""|-h|--help)
    usage; exit 0 ;;
  --list)
    list_loadouts
    exit 0 ;;
  pick)
    sel=$(pick_loadout) || exit $?
    # re-exec self with selected loadout (remaining args pass through)
    shift
    exec "$0" "$sel" "$@"
    ;;
  doctor)
    cmd_doctor
    ;;
  --dry-run)
    [[ $# -ge 2 ]] || { usage; exit 1; }
    resolve "$2"
    check_auth
    shift 2
    dry_run_report "${LLM_PRESET:-}" "$@"
    exit 0 ;;
  --*)
    usage; exit 1 ;;
  *)
    preset=$1; shift
    # Support `armory <loadout> … --dry-run` (spec a1 smoke) as well as
    # `armory --dry-run <loadout>`. --dry-run is consumed by armory and never
    # forwarded to the child CLI.
    dry_flag=0
    user_args=()
    for _arg in "$@"; do
      if [[ "$_arg" == "--dry-run" ]]; then
        dry_flag=1
      else
        user_args+=("$_arg")
      fi
    done
    set -- "${user_args[@]+"${user_args[@]}"}"

    # Sanitize before resolve so parent loadout state (from e.g. this session
    # being a grok-xhigh child) does not bleed into the requested preset.
    sanitize_parent_loadout
    resolve "$preset"
    check_auth

    if (( dry_flag )); then
      dry_run_report "${LLM_PRESET:-$preset}" "$@"
      exit 0
    fi

    preflight

    # SAGE fleet provenance (agentic-sage plan 024 companion): stamp parent
    # session id so nested armory children classify as managed_by=nested.
    # Prefer an explicit SAGE_PARENT; else inherit the advisor session's id.
    if [[ -z "${SAGE_PARENT:-}" ]]; then
      if [[ -n "${CLAUDE_SESSION_ID:-}" ]]; then
        export SAGE_PARENT="$CLAUDE_SESSION_ID"
      elif [[ -n "${GROK_SESSION_ID:-}" ]]; then
        export SAGE_PARENT="$GROK_SESSION_ID"
      fi
    fi

    if is_grok_loadout "$preset"; then
      launch_grok "$@"
    else
      launch_claude "$@"
    fi
    ;;
esac
